# ProctorAI production/local-server runtime
APP_ENV=production
LOG_LEVEL=INFO
REQUEST_LOGGING=true

# Public URLs and service ports
API_HOST=127.0.0.1
API_PORT=5051
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=8080
VIDEO_HOST=127.0.0.1
VIDEO_PORT=5050
FRONTEND_URL=http://127.0.0.1:8080
VITE_API_BASE_URL=http://127.0.0.1:5051
VITE_VIDEO_BASE_URL=http://127.0.0.1:5050
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# Runtime executables
PYTHON_EXE=C:\Path\To\python.exe
NODE_EXE=node

# Auth and bootstrap
AUTH_SECRET=replace-with-a-long-random-production-secret
# Set explicitly when the proctor sidecar/companion run on another trusted host.
PROCTOR_DEVICE_SECRET=replace-with-a-separate-long-random-device-secret
BROWSER_GUARD_TOKEN_EXPIRE_MINUTES=15
MEDIA_TOKEN_EXPIRE_MINUTES=5
ACCESS_TOKEN_EXPIRE_MINUTES=480
PASSWORD_RESET_EXPIRE_MINUTES=30
PROCTORAI_BOOTSTRAP_ADMIN_EMAIL=
PROCTORAI_BOOTSTRAP_ADMIN_PASSWORD=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5051/auth/google/callback

# SMTP password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true

# SQL Server
PROCTORAI_DB_SERVER=localhost
PROCTORAI_DB_NAME=ProctorAI_Lite
PROCTORAI_DB_TRUSTED=true
PROCTORAI_DB_DRIVER=ODBC Driver 17 for SQL Server
PROCTORAI_DB_ENCRYPT=false
PROCTORAI_DB_USER=
PROCTORAI_DB_PASSWORD=

# Storage
REPORTS_DIR=reports
SCREENSHOTS_DIR=screenshots
LOGS_DIR=logs
EXPORTS_DIR=exports
RUNTIME_DIR=runtime
BACKUP_DIR=backups

# Proctoring
AUDIO_RMS_THRESHOLD=0.08
AUDIO_COOLDOWN_SEC=20
PROCTOR_FACE_MISSING_SEC=3
PROCTOR_EVENT_COOLDOWN_SEC=20
PROCTOR_LOW_LIGHT_THRESHOLD=45
WEBCAM_INDEX=0
WEBCAM_INDEX_SECONDARY=-1
WEBCAM_FROZEN_DIFF_THRESHOLD=0.05
WEBCAM_FROZEN_SECONDS=8
PHONE_MODEL_PATH=models/phone_detector.onnx
PHONE_MODEL_CLASSES=models/coco.names
PHONE_CONFIDENCE_THRESHOLD=0.35
BROWSER_GUARD_AUTO_START=true
