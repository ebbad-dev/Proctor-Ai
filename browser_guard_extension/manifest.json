{
  "manifest_version": 3,
  "name": "ProctorAI Browser Guard",
  "version": "1.0.0",
  "description": "Reports active exam tab, URL, focus, keyboard, clipboard, and fullscreen events to the local ProctorAI backend.",
  "permissions": ["tabs", "activeTab", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1:5051/*", "http://localhost:5051/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "ProctorAI Browser Guard"
  }
}
